# .env.lando
# Local secrets for Lando tooling commands.
# NEVER commit this file. It is listed in .gitignore.
# Copy this file to .env.lando and fill in your values.

# ── Cloudways SSH access (for lando db-pull) ─────────────────
# Find these in Cloudways dashboard → Server → Master Credentials
CLOUDWAYS_SSH=master.xxxxxxxxxxxx@host.cloudwaysapps.com
CLOUDWAYS_WP_PATH=/home/master/applications/djxudszeqq/public_html

# ── Production URLs ──────────────────────────────────────────
CLOUDWAYS_PROD_URL=https://wellthisiissports.com

# ── Pipeline API key (must match wtis_pipeline_api_key in WP) ─
WTIS_PIPELINE_API_KEY=your-secure-api-key-here
